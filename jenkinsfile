pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    environment {

        IMAGE_NAME = "bazeemme/my-demo-project-repo"
        
        AWS_BUCKET = "kustomize-demo"
    }

    stages {

    

        stage('Checkout') {
            steps {

                git branch: 'master',
                url: 'https://github.com/baseemibnbasheer8-dotcom/demo-project-kustomize.git'
            }
        }

        

        stage('Build') {
            steps {

                sh 'mvn clean verify'
            }
        }

       

        stage('Unit Test') {
            steps {

                sh 'mvn test'
            }
        }

        

        stage('SonarQube Analysis') {
            steps {

                withSonarQubeEnv('SonarQube') {

                    sh 'mvn sonar:sonar'
                }
            }
        }

        

        stage('Quality Gate') {
            steps {

                timeout(time: 5, unit: 'MINUTES') {

                    waitForQualityGate abortPipeline: true
                }
            }
        }

        

        stage('Docker Login') {
            steps {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'docker-cred',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {

                    sh '''
                    echo $DOCKER_PASS | docker login \
                    -u $DOCKER_USER --password-stdin
                    '''
                }
            }
        }

        
        stage('Docker Build') {
            steps {

                sh '''
                docker build -t $IMAGE_NAME:$BUILD_NUMBER .
                '''
            }
        }

        
        stage('Docker Push') {
            steps {

                sh '''
                docker push $IMAGE_NAME:$BUILD_NUMBER
                '''
            }
        }

        

        stage('Docker Logout') {
            steps {

                sh 'docker logout'
            }
        }

        

        stage('Update Kustomization Image Tag') {
            steps {

                sh """
                sed -i 's|newTag:.*|newTag: "${BUILD_NUMBER}"|g' \
                kustomize-dir/overlay/dev/kustomization.yaml
                """
            }
        }

        



        stage('Set Package Name') {
            steps {

                script {

                    env.PACKAGE_NAME = "kustomize-package-${BUILD_NUMBER}.tar.gz"
                }
            }
        }
        stage('Archive Kustomize Package') {
            steps {

                sh '''
                tar -czf  $PACKAGE_NAME kustomize-dir/
                '''
            }
        }

       

        stage('Upload Package to S3') {
            steps {

                withCredentials([
                    [
                        $class: 'AmazonWebServicesCredentialsBinding',
                        credentialsId: 'aws-creds',
                        accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                        secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                    ]
                ]) {

                    sh '''
                    aws s3 cp $PACKAGE_NAME \
                    s3://$AWS_BUCKET/
                    '''
                }
            }
        }

        

        stage('Trigger Deploy Job') {
            steps {

                build job: 'deploy-job-kustomize',
                parameters: [
                    string(name: 'IMAGE_TAG', value: "${BUILD_NUMBER}"),
                    string(name: 'PACKAGE_NAME', value: "${PACKAGE_NAME}")
                ]
            }
        }
    }

    post {

        success {

            echo 'Kustomize Build Pipeline Completed Successfully'
        }

        failure {

            echo 'Pipeline Failed'
        }
    }
}
