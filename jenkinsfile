pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    environment {
        IMAGE_NAME = "bazeemme/my-demo-project-repo"
        CHART_NAME = "demo-project-chart"
        CHART_VERSION = "0.1.0"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/baseemibnbasheer8-dotcom/demo-project.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean verify'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh 'mvn sonar:sonar'
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        // ---------------- DOCKER ----------------

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-cred',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t $IMAGE_NAME:$BUILD_NUMBER .'
            }
        }

        stage('Docker Push') {
            steps {
                sh 'docker push $IMAGE_NAME:$BUILD_NUMBER'
            }
        }

        // ---------------- HELM ----------------

        stage('Update Chart Version') {
            steps {
                sh """
                sed -i 's/^version:.*/version: 0.1.${BUILD_NUMBER}/' demo-project-chart/Chart.yaml
                """
            }
        }

        stage('Package Helm Chart') {
            steps {
                sh 'helm package demo-project-chart'
            }
        }

        stage('Helm Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-cred',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh 'echo $DOCKER_PASS | helm registry login registry-1.docker.io -u $DOCKER_USER --password-stdin'
                }
            }
        }

        stage('Push Helm Chart') {
            steps {
                sh """
                CHART_PACKAGE=$(ls *.tgz)
                helm push $CHART_PACKAGE oci://registry-1.docker.io/bazeemme
                """
            }
        }

        // ---------------- DEPLOY TRIGGER ----------------

        stage('Trigger Deploy Job') {
            steps {
                build job: 'deploy-job', parameters: [
                    string(name: 'IMAGE_TAG', value: "${BUILD_NUMBER}"),
                    string(name: 'CHART_VERSION', value: "0.1.${BUILD_NUMBER}")
                ]
            }
        }
    }
}
